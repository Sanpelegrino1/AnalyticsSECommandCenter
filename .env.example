# Copy this file to .env.local and fill in only the values you actually use.

SF_DEFAULT_ALIAS=
SF_LOGIN_URL=https://login.salesforce.com

DATACLOUD_DEFAULT_TARGET=
DATACLOUD_LOGIN_URL=https://login.salesforce.com
DATACLOUD_SALESFORCE_ALIAS=
# Leave blank by default. scripts/salesforce/setup-command-center-connected-app.ps1 now deploys
# a per-org CommandCenterAuth client id and records it in notes/registries/salesforce-orgs.json.
DATACLOUD_CLIENT_ID=
DATACLOUD_CLIENT_SECRET=
DATACLOUD_REFRESH_TOKEN=
DATACLOUD_TOKEN_EXCHANGE_URL=
DATACLOUD_TENANT_ENDPOINT=
DATACLOUD_ACCESS_TOKEN=
DATACLOUD_SF_ACCESS_TOKEN=

TABLEAU_SERVER_URL=https://prod-useast-a.online.tableau.com
TABLEAU_SITE_CONTENT_URL=
TABLEAU_DEFAULT_TARGET=
TABLEAU_DEFAULT_PROJECT_ID=
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=
TABLEAU_API_VERSION=3.24

# Slack shared MCP setup is workspace-local through .vscode/mcp.json.
# Store the shared server URL outside tracked files if you do not want to enter it
# through VS Code's input prompt on first start.
SLACK_MCP_SERVER_URL=
