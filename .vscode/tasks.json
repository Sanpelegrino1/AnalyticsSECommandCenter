{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bootstrap: Audit workspace machine",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\bootstrap\\setup-workspace.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Bootstrap: Install missing prerequisites",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\bootstrap\\setup-workspace.ps1",
        "-InstallMissing"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Login web and register alias",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\login-web.ps1",
        "-Alias",
        "${input:sfAlias}",
        "-InstanceUrl",
        "${input:sfInstanceUrl}",
        "-Purpose",
        "${input:sfPurpose}",
        "-Notes",
        "${input:sfNotes}",
        "-SetDefault"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: List orgs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\list-orgs.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Set default org",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\set-default-org.ps1",
        "-Alias",
        "${input:sfAlias}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Open org",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\open-org.ps1",
        "-TargetOrg",
        "${input:sfAlias}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Run SOQL and export",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\run-soql.ps1",
        "-TargetOrg",
        "${input:sfAlias}",
        "-Query",
        "${input:sfSoql}",
        "-OutputPath",
        "${workspaceFolder}\\tmp\\soql-export.csv"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Retrieve metadata",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\retrieve-metadata.ps1",
        "-TargetOrg",
        "${input:sfAlias}",
        "-ManifestPath",
        "manifest/package.xml"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\salesforce"
      },
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Deploy metadata",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\deploy-metadata.ps1",
        "-TargetOrg",
        "${input:sfAlias}",
        "-ManifestPath",
        "manifest/package.xml"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\salesforce"
      },
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Snapshot aliases",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\snapshot-aliases.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce Data Cloud: Inspect CSV",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\data-cloud-inspect-csv.ps1",
        "-CsvPath",
        "${input:dataCloudCsvPath}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce Data Cloud: Upload CSV",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\data-cloud-upload-csv.ps1",
        "-TargetKey",
        "${input:dataCloudTargetKey}",
        "-CsvPath",
        "${input:dataCloudCsvPath}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce Data Cloud: List ingestion jobs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\data-cloud-list-jobs.ps1",
        "-TargetKey",
        "${input:dataCloudTargetKey}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce Data Cloud: Get job info",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\data-cloud-get-job.ps1",
        "-TargetKey",
        "${input:dataCloudTargetKey}",
        "-JobId",
        "${input:dataCloudJobId}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce Data Cloud: Guided manifest setup",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\data-cloud-guided-manifest-setup.ps1",
        "-ManifestPath",
        "${input:dataCloudManifestPath}",
        "-Alias",
        "${input:dataCloudAlias}",
        "-LoginUrl",
        "${input:dataCloudLoginUrl}",
        "-TargetKeyPrefix",
        "${input:dataCloudTargetKeyPrefix}",
        "-SourceName",
        "${input:dataCloudSourceName}",
        "-ObjectNamePrefix",
        "${input:dataCloudObjectNamePrefix}",
        "-Category",
        "${input:dataCloudCategory}",
        "-Notes",
        "${input:dataCloudNotes}",
        "-SetDefault"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Build manifest semantic-model spec",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\build-manifest-semantic-model-spec.ps1",
        "-ManifestPath",
        "${input:dataCloudManifestPath}",
        "-ProvisioningReportPath",
        "${workspaceFolder}\\salesforce\\generated\\${input:dataCloudSourceName}\\provisioning-state.json",
        "-TargetKey",
        "${input:tableauNextTargetKey}",
        "-TargetKeyPrefix",
        "${input:dataCloudTargetKeyPrefix}",
        "-ModelApiName",
        "${input:tableauNextModelApiName}",
        "-ModelLabel",
        "${input:tableauNextModelLabel}",
        "-OutputPath",
        "${workspaceFolder}\\tmp\\tableau-next-sdm.spec.json"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Orchestrate authenticated to SDM",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\orchestrate-authenticated-to-sdm.ps1",
        "-ManifestPath",
        "${input:dataCloudManifestPath}",
        "-TargetOrg",
        "${input:sfAlias}",
        "-DataCloudAlias",
        "${input:dataCloudAlias}",
        "-SourceName",
        "${input:dataCloudSourceName}",
        "-TargetKeyPrefix",
        "${input:dataCloudTargetKeyPrefix}",
        "-ObjectNamePrefix",
        "${input:dataCloudObjectNamePrefix}",
        "-TableauNextTargetKey",
        "${input:tableauNextTargetKey}",
        "-WorkspaceDeveloperName",
        "${input:tableauNextWorkspaceDeveloperName}",
        "-ModelApiName",
        "${input:tableauNextModelApiName}",
        "-ModelLabel",
        "${input:tableauNextModelLabel}",
        "-OutputPath",
        "${workspaceFolder}\\tmp\\authenticated-to-sdm-state.json"
      ],
      "problemMatcher": []
    },
    {
      "label": "Salesforce: Orchestrate authenticated to SDM and apply",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\salesforce\\orchestrate-authenticated-to-sdm.ps1",
        "-ManifestPath",
        "${input:dataCloudManifestPath}",
        "-TargetOrg",
        "${input:sfAlias}",
        "-DataCloudAlias",
        "${input:dataCloudAlias}",
        "-SourceName",
        "${input:dataCloudSourceName}",
        "-TargetKeyPrefix",
        "${input:dataCloudTargetKeyPrefix}",
        "-ObjectNamePrefix",
        "${input:dataCloudObjectNamePrefix}",
        "-TableauNextTargetKey",
        "${input:tableauNextTargetKey}",
        "-WorkspaceDeveloperName",
        "${input:tableauNextWorkspaceDeveloperName}",
        "-ModelApiName",
        "${input:tableauNextModelApiName}",
        "-ModelLabel",
        "${input:tableauNextModelLabel}",
        "-ApplySemanticModel",
        "-OutputPath",
        "${workspaceFolder}\\tmp\\authenticated-to-sdm-apply-state.json"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau: Auth status",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\auth-status.ps1",
        "-TargetKey",
        "${input:tableauTargetKey}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau: List projects",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\list-projects.ps1",
        "-TargetKey",
        "${input:tableauTargetKey}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau: List content",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\list-content.ps1",
        "-TargetKey",
        "${input:tableauTargetKey}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau Next: List workspaces",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\list-next-workspaces.ps1",
        "-TargetOrg",
        "${input:sfAlias}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau Next: List semantic models",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\list-next-semantic-models.ps1",
        "-TargetOrg",
        "${input:sfAlias}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau Next: Register target",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\register-next-target.ps1",
        "-TargetKey",
        "${input:tableauNextTargetKey}",
        "-TargetOrg",
        "${input:sfAlias}",
        "-WorkspaceId",
        "${input:tableauNextWorkspaceId}",
        "-SemanticModelId",
        "${input:tableauNextSemanticModelId}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau Next: Inspect target",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\inspect-next-target.ps1",
        "-TargetKey",
        "${input:tableauNextTargetKey}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau Next: Inspect semantic model",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\inspect-next-semantic-model.ps1",
        "-TargetKey",
        "${input:tableauNextTargetKey}",
        "-SemanticModelId",
        "${input:tableauNextSemanticModelInspectId}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau Next: Build semantic-model request",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\upsert-next-semantic-model.ps1",
        "-TargetKey",
        "${input:tableauNextTargetKey}",
        "-ModelApiName",
        "${input:tableauNextModelApiName}",
        "-ModelLabel",
        "${input:tableauNextModelLabel}",
        "-ObjectApiName",
        "${input:tableauNextObjectApiNames}",
        "-PrimaryObjectApiName",
        "${input:tableauNextPrimaryObjectApiName}",
        "-OutputPath",
        "${workspaceFolder}\\tmp\\tableau-next-sdm.request.json",
        "-Json"
      ],
      "problemMatcher": []
    },
    {
      "label": "Tableau: Snapshot targets",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\tableau\\snapshot-targets.ps1"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "sfAlias",
      "type": "promptString",
      "description": "Salesforce alias",
      "default": "MY_DEMO_ORG"
    },
    {
      "id": "sfInstanceUrl",
      "type": "promptString",
      "description": "Salesforce login or My Domain URL",
      "default": "https://login.salesforce.com"
    },
    {
      "id": "sfPurpose",
      "type": "promptString",
      "description": "Why this org exists",
      "default": "Demo setup"
    },
    {
      "id": "sfNotes",
      "type": "promptString",
      "description": "Non-secret notes for the org registry",
      "default": ""
    },
    {
      "id": "sfSoql",
      "type": "promptString",
      "description": "SOQL query",
      "default": "SELECT Id, Name FROM Account LIMIT 20"
    },
    {
      "id": "dataCloudTargetKey",
      "type": "promptString",
      "description": "Data Cloud target key from notes/registries/data-cloud-targets.json",
      "default": "default"
    },
    {
      "id": "dataCloudCsvPath",
      "type": "promptString",
      "description": "Path to the CSV file to inspect or upload",
      "default": "${workspaceFolder}\\tmp\\data-cloud-upload.csv"
    },
    {
      "id": "dataCloudJobId",
      "type": "promptString",
      "description": "Data Cloud ingestion job id",
      "default": ""
    },
    {
      "id": "dataCloudManifestPath",
      "type": "promptString",
      "description": "Path to the manifest.json file for a multi-table dataset",
      "default": "${workspaceFolder}\\Demos\\Sunrun Demo\\manifest.json"
    },
    {
      "id": "dataCloudAlias",
      "type": "promptString",
      "description": "Dedicated Data Cloud auth alias",
      "default": "STORM_TABLEAU_NEXT_DC"
    },
    {
      "id": "dataCloudLoginUrl",
      "type": "promptString",
      "description": "Salesforce login or My Domain URL for Data Cloud auth",
      "default": "https://storm-8bdc14a63d953e.my.salesforce.com"
    },
    {
      "id": "dataCloudTargetKeyPrefix",
      "type": "promptString",
      "description": "Prefix for generated Data Cloud target keys",
      "default": "sunrun"
    },
    {
      "id": "dataCloudSourceName",
      "type": "promptString",
      "description": "Shared Data Cloud sourceName for the dataset",
      "default": "sunrun_ingest_api"
    },
    {
      "id": "dataCloudObjectNamePrefix",
      "type": "promptString",
      "description": "Prefix for generated Data Cloud object names",
      "default": "sunrun"
    },
    {
      "id": "dataCloudTenantEndpoint",
      "type": "promptString",
      "description": "Tenant endpoint if already known; leave blank to derive during auth/validation",
      "default": ""
    },
    {
      "id": "dataCloudCategory",
      "type": "promptString",
      "description": "Category label for generated targets",
      "default": "Sunrun Residential Solar Operations"
    },
    {
      "id": "dataCloudNotes",
      "type": "promptString",
      "description": "Non-secret notes to store with generated targets",
      "default": "Guided manifest setup"
    },
    {
      "id": "tableauTargetKey",
      "type": "promptString",
      "description": "Tableau target key from notes/registries/tableau-targets.json",
      "default": "default"
    },
    {
      "id": "tableauNextTargetKey",
      "type": "promptString",
      "description": "Tableau Next target key",
      "default": "juju-demo-sdm"
    },
    {
      "id": "tableauNextWorkspaceId",
      "type": "promptString",
      "description": "Tableau Next workspace id",
      "default": "1DyKZ000000kA8f0AE"
    },
    {
      "id": "tableauNextWorkspaceDeveloperName",
      "type": "promptString",
      "description": "Tableau Next workspace developer name",
      "default": "Juju_Demo"
    },
    {
      "id": "tableauNextSemanticModelId",
      "type": "promptString",
      "description": "Existing Tableau Next semantic model id (optional)",
      "default": ""
    },
    {
      "id": "tableauNextSemanticModelInspectId",
      "type": "promptString",
      "description": "Semantic model id to inspect when the target does not already pin one",
      "default": ""
    },
    {
      "id": "tableauNextModelApiName",
      "type": "promptString",
      "description": "Semantic model API name",
      "default": "Juju_Demo_Semantic"
    },
    {
      "id": "tableauNextModelLabel",
      "type": "promptString",
      "description": "Semantic model label",
      "default": "Juju Demo Semantic"
    },
    {
      "id": "tableauNextObjectApiNames",
      "type": "promptString",
      "description": "Comma-separated Data Cloud object API names",
      "default": "sunrun2_projects,sunrun2_affiliates"
    },
    {
      "id": "tableauNextPrimaryObjectApiName",
      "type": "promptString",
      "description": "Primary Data Cloud object API name",
      "default": "sunrun2_projects"
    }
  ]
}
